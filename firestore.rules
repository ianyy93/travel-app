rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidItinerary(data) {
      return data.days is list;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "ianyy93@gmail.com" || request.auth.token.email == "wingin.carrie@gmail.com");
    }

    match /trips/{tripId} {
      // Allow anyone to view public trips, but only admins can edit
      allow get, list: if true;
      allow write: if isAdmin() && isValidItinerary(request.resource.data);
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
