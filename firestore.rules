rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidItinerary(data) {
      return data.days is list;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "ianyy93@gmail.com" || request.auth.token.email == "wingin.carrie@gmail.com");
    }

    function isValidTravellersSettings(data) {
      return data.list is list;
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && (settingId != 'travellers' || isValidTravellersSettings(request.resource.data));
    }

    match /trips/{tripId} {
      // Allow anyone to view public trips, but only admins can edit
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidItinerary(request.resource.data);
      allow delete: if isAdmin();

      match /history/{historyId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
