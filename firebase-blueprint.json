{
  "entities": {
    "itinerary": {
      "title": "Itinerary",
      "description": "The travel itinerary data",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "dates": { "type": "string" },
        "days": {
          "type": "array",
          "items": {
            "$ref": "dayPlan"
          }
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        },
        "updatedBy": {
          "type": "string"
        }
      },
      "required": ["days"]
    },
    "dayPlan": {
      "title": "Day Plan",
      "description": "A single day's plan",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "activity"
          }
        }
      },
      "required": ["date", "title", "activities"]
    },
    "activity": {
      "title": "Activity",
      "description": "A single activity",
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["flight", "drive", "stay", "activity", "food", "work"] },
        "location": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["title", "type"]
    },
    "tripMember": {
      "title": "Trip Member",
      "description": "A person travelling on a trip",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "initials": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "initials", "color"]
    },
    "travellersSettings": {
      "title": "Travellers Settings",
      "description": "Master list of travellers",
      "type": "object",
      "properties": {
        "list": {
          "type": "array",
          "items": { "$ref": "tripMember" }
        }
      },
      "required": ["list"]
    }
  },
  "firestore": {
    "/trips/{tripId}": {
      "schema": "itinerary",
      "description": "A shared trip itinerary"
    },
    "/settings/travellers": {
      "schema": "travellersSettings",
      "description": "Master list of travellers for all trips"
    }
  }
}
